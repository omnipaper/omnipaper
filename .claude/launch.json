{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--cwd", "apps/web", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "docs-static",
      "runtimeExecutable": "bunx",
      "runtimeArgs": ["serve", "-l", "4949", "apps/docs/.output/public"],
      "port": 4949
    }
  ]
}
